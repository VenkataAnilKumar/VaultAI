modules = ["nodejs-20"]
run = "cd src/webapp && npm install && npm run dev"
entrypoint = "src/webapp/package.json"
hidden = [".config", ".git", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 23636
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Vault AI"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src/webapp && npm run dev"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Install Only"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src/webapp && npm install"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Vault AI Landing"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Vault AI"

[[workflows.workflow]]
name = "Vault AI Landing"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd src/landing && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
run = ["sh", "-c", "cd src/webapp && npm run start"]
build = ["sh", "-c", "cd src/webapp && npm install && npm run build"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
